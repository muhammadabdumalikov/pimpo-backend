# Copy to .env and fill in values

# Server
PORT=3000

# Database
# Local dev / docker-compose default (matches docker-compose.yml credentials).
# When the API itself runs inside docker-compose, the host is `postgres`.
DATABASE_URL=postgresql://pimpo:pimpo@localhost:5432/pimpo

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=604800

# Platform admin token — required (via X-Admin-Token header) to create/update/
# delete the global subscription plans. Leave unset to keep those endpoints
# fully locked (deny-by-default).
ADMIN_API_TOKEN=change-me-platform-admin-token

# S3-compatible storage (e.g. AWS S3, Hetzner Object Storage)
S3_BUCKET=pimpo
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_ENDPOINT=https://fsn1.your-objectstorage.com
# Optional: custom base URL for public links (default: S3_ENDPOINT/S3_BUCKET)
# S3_PUBLIC_BASE_URL=https://fsn1.your-objectstorage.com/pimpo

# Store (for public store API)
# STORE_BUSINESS_ID=your-business-id
