# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pimpo

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=604800

# S3-compatible storage (e.g. AWS S3, Hetzner Object Storage)
S3_BUCKET=pimpo
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_ENDPOINT=https://fsn1.your-objectstorage.com
# Optional: custom base URL for public links (default: S3_ENDPOINT/S3_BUCKET)
# S3_PUBLIC_BASE_URL=https://fsn1.your-objectstorage.com/pimpo

# Store (for public store API)
# STORE_BUSINESS_ID=your-business-id
